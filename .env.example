# Copy this file to .env and fill values for your machine.
# Never commit .env

# Core services
UNIFIED_DETECTION_URL=http://127.0.0.1:8001
UNIFIED_RPI_SOURCE_URL=http://127.0.0.1:9100

# NSU local defaults
NSU_LOCAL_FRAMES_DIR=public/images
NSU_LOCAL_FRAMES_COCO=public/annotations/val_from_labels.json

# Detection runtime
DET_DEVICE=cpu
PRELOAD_STREAM_MODELS=1
NANODET_ONNX=0
REQUIRE_NANODET_PTH=1
REQUIRE_NANODET_ONNX=1
REQUIRE_YOLO_ONNX=1

# Stream init tuning
STREAM_REMOTE_INIT_TIMEOUT_SEC=90

# Optional model paths
YOLO_WEIGHTS_PATH=models/yolov8n_baseline_multiscale.pt
YOLO_ONNX_PATH=models/yolov8n_baseline_multiscale.onnx
NANODET_CONFIG=nanodet/config/nanodet-plus-m-1.5x_416.yml
NANODET_WEIGHTS=nanodet/nanodet/model/weights/nanodet-plus-m-1.5x_416.pth
NANODET_ONNX_PATH=nanodet/nanodet/model/weights/nanodet-plus-m-1.5x_416.onnx

# Optional remote model URLs
YOLO_WEIGHTS_URL=
YOLO_ONNX_URL=
NANODET_PTH_URL=
NANODET_ONNX_URL=
NANODET_CONFIG_URL=

# Raspberry Pi source-service paths (on Pi)
RPI_VIDEO_DIR=/home/pi/Documents/test_videos
RPI_MISSIONS_DIR=/home/pi/Documents/missions
RPI_RTSP_HOST=
RPI_RTSP_PORT=8554
RPI_RTSP_PATH_PREFIX=live
RPI_RTSP_ENABLE=1
